{
  "name": "laikacms",
  "version": "0.1.0",
  "description": "The basis for modern content management.",
  "keywords": [
    "headless-cms",
    "content-management",
    "jamstack",
    "react",
    "typescript"
  ],
  "author": {
    "name": "Sem Postma",
    "email": "sem@laikacms.com",
    "url": "https://sem-postma.com"
  },
  "homepage": "https://github.com/laikacms/laikacms",
  "bugs": {
    "email": "sem@laikacms.com",
    "url": "https://github.com/laikacms/laikacms/issues"
  },
  "license": "MIT",
  "contributors": [],
  "maintainers": [],
  "repository": "https://github.com/laikacms/laikacms",
  "funding": {
    "type": "github",
    "url": "https://github.com/laikacms/laikacms/sponsors"
  },
  "scripts": {
    "clean": "rimraf --glob '**/node_modules' '**/dist' '**/.turbo' '**/cdk.out' '**/.tanstack/*' '**/.wrangler/*'",
    "build": "turbo run build",
    "dev": "turbo watch dev",
    "types": "turbo run types",
    "test": "turbo run test",
    "coverage": "turbo run test -- --coverage --coverage.reporter=text-summary --coverage.reporter=lcov --coverage.reporter=html",
    "link:global": "turbo run link",
    "scripts:validate-packages": "tsx scripts/validate-packages.ts",
    "lint": "eslint --cache --config eslint.config.mjs .",
    "lint:fix": "eslint --fix --cache --config eslint.config.mjs .",
    "format": "dprint fmt",
    "format:check": "dprint check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "catalog:lint",
    "@types/node": "catalog:types",
    "@typescript-eslint/eslint-plugin": "catalog:lint",
    "@typescript-eslint/parser": "catalog:lint",
    "@vitest/coverage-v8": "catalog:tools",
    "eslint": "catalog:lint",
    "globals": "catalog:lint",
    "husky": "^9.1.7",
    "immutable": "catalog:legacy",
    "rimraf": "catalog:tools",
    "turbo": "catalog:tools",
    "typescript": "catalog:tools",
    "typescript-eslint": "catalog:lint"
  },
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": "22.x",
    "pnpm": ">=8 <11"
  }
}
