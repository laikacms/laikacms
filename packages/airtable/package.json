{
  "name": "@laikacms/airtable",
  "version": "1.0.0",
  "description": "Airtable-backed StorageRepository for Laika CMS. `filterByFormula` for queries, chunked batch mutations (Airtable's 10-record cap). Runtime-agnostic — only depends on `fetch`.",
  "keywords": [
    "headless-cms",
    "content-management",
    "airtable",
    "storage"
  ],
  "author": {
    "name": "Sem Postma",
    "email": "sem@laikacms.com",
    "url": "https://sem-postma.com"
  },
  "homepage": "https://github.com/laikacms/laikacms",
  "bugs": {
    "email": "sem@laikacms.com",
    "url": "https://github.com/laikacms/laikacms/issues"
  },
  "license": "MIT",
  "repository": "https://github.com/laikacms/laikacms",
  "type": "module",
  "sideEffects": false,
  "files": ["dist", "README.md", "LICENSE", "CHANGELOG.md"],
  "exports": {
    "./storage-airtable": {
      "types": "./dist/storage-airtable/index.d.ts",
      "import": "./dist/storage-airtable/index.js",
      "default": "./dist/storage-airtable/index.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist .turbo",
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "laikacms": "workspace:*",
    "effect": "catalog:default"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "rimraf": "catalog:tools",
    "typescript": "catalog:tools",
    "vitest": "catalog:tools"
  },
  "engines": { "node": ">=22" }
}
