{
  "name": "@laikacms/decap-ai",
  "version": "1.0.0",
  "description": "AI chat integration for Decap CMS: server adapter, React widget, model providers, all bundled with their own ai SDK runtime so consumers stay decoupled.",
  "keywords": [
    "decap-cms",
    "ai",
    "headless-cms",
    "vercel-ai-sdk"
  ],
  "author": {
    "name": "Sem Postma",
    "email": "sem@laikacms.com",
    "url": "https://sem-postma.com"
  },
  "homepage": "https://github.com/laikacms/laikacms",
  "bugs": {
    "email": "sem@laikacms.com",
    "url": "https://github.com/laikacms/laikacms/issues"
  },
  "license": "MIT",
  "repository": "https://github.com/laikacms/laikacms",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools/index.js",
      "default": "./dist/tools/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.js",
      "default": "./dist/providers/index.js"
    },
    "./widget": {
      "types": "./dist/widget/index.d.ts",
      "import": "./dist/widget/index.js",
      "default": "./dist/widget/index.js"
    },
    "./widget/i18n/types": {
      "types": "./dist/widget/i18n/types.d.ts",
      "import": "./dist/widget/i18n/types.js",
      "default": "./dist/widget/i18n/types.js"
    },
    "./widget/i18n/en": {
      "types": "./dist/widget/i18n/en.d.ts",
      "import": "./dist/widget/i18n/en.js",
      "default": "./dist/widget/i18n/en.js"
    },
    "./widget/i18n/nl": {
      "types": "./dist/widget/i18n/nl.d.ts",
      "import": "./dist/widget/i18n/nl.js",
      "default": "./dist/widget/i18n/nl.js"
    },
    "./i18n/types": {
      "types": "./dist/i18n/types.d.ts",
      "import": "./dist/i18n/types.js",
      "default": "./dist/i18n/types.js"
    },
    "./i18n/en": {
      "types": "./dist/i18n/en.d.ts",
      "import": "./dist/i18n/en.js",
      "default": "./dist/i18n/en.js"
    },
    "./i18n/nl": {
      "types": "./dist/i18n/nl.d.ts",
      "import": "./dist/i18n/nl.js",
      "default": "./dist/i18n/nl.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist .turbo",
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "laikacms": "workspace:*",
    "@ai-sdk/anthropic": "catalog:ai",
    "@ai-sdk/openai": "catalog:ai",
    "@ai-sdk/react": "catalog:ai",
    "ai": "catalog:ai",
    "aws-jwt-verify": "catalog:aws",
    "effect": "catalog:default",
    "fast-json-patch": "^3.1.1",
    "jsonwebtoken": "^9.0.2",
    "jwt-decode": "^4.0.0",
    "uuid": "^13.0.0",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "@emotion/css": "catalog:legacy",
    "@emotion/react": "catalog:legacy",
    "decap-cms-core": "catalog:decap",
    "decap-cms-lib-util": "catalog:decap",
    "decap-cms-ui-default": "catalog:decap",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "react-redux": "^7.2.0"
  },
  "peerDependenciesMeta": {
    "@emotion/css": {
      "optional": true
    },
    "@emotion/react": {
      "optional": true
    },
    "decap-cms-core": {
      "optional": true
    },
    "decap-cms-lib-util": {
      "optional": true
    },
    "decap-cms-ui-default": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "react-redux": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "@types/jwt-decode": "^3.1.0",
    "@types/node": "catalog:types",
    "@types/react": "catalog:types",
    "@types/react-dom": "catalog:types",
    "@types/react-redux": "^7.1.34",
    "@types/uuid": "^10.0.0",
    "immutable": "catalog:legacy",
    "rimraf": "catalog:tools",
    "typescript": "catalog:tools",
    "vitest": "catalog:tools"
  },
  "engines": {
    "node": "22.x"
  }
}
