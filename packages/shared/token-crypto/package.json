{
  "name": "@laikacms/token-crypto",
  "version": "0.1.0",
  "description": "Cryptographic utilities for Laika CMS tokens (Ed25519 signing and verification using Node.js crypto)",
  "author": "Sem Postma <sem@esstudio.nl>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rimraf dist .turbo node_modules"
  },
  "keywords": [
    "laika-cms",
    "crypto",
    "ed25519",
    "tokens",
    "signing"
  ],
  "license": "MIT",
  "dependencies": {
    "@laikacms/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": "22.x",
    "pnpm": ">=8 <11"
  }
}
