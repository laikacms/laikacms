{
  "name": "@laikacms/decap-integrations",
  "version": "1.0.0",
  "description": "Decap CMS integrations for Laika CMS: backend, OAuth2, widgets, server adapters. AI chat lives in @laikacms/decap-ai. The Decap CMS shell itself (App, DecapCmsProvider, widgets) lives in the upstream-named `@laikacms/decap` fork.",
  "keywords": [
    "decap-cms",
    "headless-cms",
    "oauth2",
    "widgets"
  ],
  "author": {
    "name": "Sem Postma",
    "email": "sem@laikacms.com",
    "url": "https://sem-postma.com"
  },
  "homepage": "https://github.com/laikacms/laikacms",
  "bugs": {
    "email": "sem@laikacms.com",
    "url": "https://github.com/laikacms/laikacms/issues"
  },
  "license": "MIT",
  "repository": "https://github.com/laikacms/laikacms",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "exports": {
    "./decap-api": {
      "types": "./dist/decap-api/index.d.ts",
      "import": "./dist/decap-api/index.js",
      "default": "./dist/decap-api/index.js"
    },
    "./embedded": {
      "types": "./dist/embedded/index.d.ts",
      "import": "./dist/embedded/index.js",
      "default": "./dist/embedded/index.js"
    },
    "./workers": {
      "types": "./dist/workers/index.d.ts",
      "import": "./dist/workers/index.js",
      "default": "./dist/workers/index.js"
    },
    "./custom": {
      "types": "./dist/custom/index.d.ts",
      "import": "./dist/custom/index.js",
      "default": "./dist/custom/index.js"
    },
    "./decap-config-types": {
      "types": "./dist/decap-config-types/index.d.ts",
      "import": "./dist/decap-config-types/index.js",
      "default": "./dist/decap-config-types/index.js"
    },
    "./decap-cms-backend-laika": {
      "types": "./dist/decap-cms-backend-laika/index.d.ts",
      "import": "./dist/decap-cms-backend-laika/index.js",
      "default": "./dist/decap-cms-backend-laika/index.js"
    },
    "./decap-cms-editor-component-embedded-entry": {
      "types": "./dist/decap-cms-editor-component-embedded-entry/index.d.ts",
      "import": "./dist/decap-cms-editor-component-embedded-entry/index.js",
      "default": "./dist/decap-cms-editor-component-embedded-entry/index.js"
    },
    "./decap-cms-locale-nl": {
      "types": "./dist/decap-cms-locale-nl/index.d.ts",
      "import": "./dist/decap-cms-locale-nl/index.js",
      "default": "./dist/decap-cms-locale-nl/index.js"
    },
    "./decap-cms-widget-lucide-icon": {
      "types": "./dist/decap-cms-widget-lucide-icon/index.d.ts",
      "import": "./dist/decap-cms-widget-lucide-icon/index.js",
      "default": "./dist/decap-cms-widget-lucide-icon/index.js"
    },
    "./decap-cms-widget-radix-icon": {
      "types": "./dist/decap-cms-widget-radix-icon/index.d.ts",
      "import": "./dist/decap-cms-widget-radix-icon/index.js",
      "default": "./dist/decap-cms-widget-radix-icon/index.js"
    },
    "./decap-oauth2": {
      "types": "./dist/decap-oauth2/index.d.ts",
      "import": "./dist/decap-oauth2/index.js",
      "default": "./dist/decap-oauth2/index.js"
    },
    "./decap-oauth2/i18n": {
      "types": "./dist/decap-oauth2/i18n/index.d.ts",
      "import": "./dist/decap-oauth2/i18n/index.js",
      "default": "./dist/decap-oauth2/i18n/index.js"
    },
    "./decap-oauth2/i18n/en": {
      "types": "./dist/decap-oauth2/i18n/translations/en.d.ts",
      "import": "./dist/decap-oauth2/i18n/translations/en.js",
      "default": "./dist/decap-oauth2/i18n/translations/en.js"
    },
    "./decap-oauth2/i18n/nl": {
      "types": "./dist/decap-oauth2/i18n/translations/nl.d.ts",
      "import": "./dist/decap-oauth2/i18n/translations/nl.js",
      "default": "./dist/decap-oauth2/i18n/translations/nl.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist .turbo",
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "laikacms": "workspace:*",
    "aws-jwt-verify": "catalog:aws",
    "effect": "catalog:default",
    "jsonwebtoken": "^9.0.2",
    "jwt-decode": "^4.0.0",
    "uuid": "^13.0.0",
    "yaml": "^2.8.0",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "@emotion/css": "catalog:legacy",
    "@emotion/react": "catalog:legacy",
    "@octokit/rest": "catalog:octokit",
    "@radix-ui/react-icons": "catalog:icons",
    "decap-cms-backend-github": "catalog:decap",
    "decap-cms-core": "catalog:decap",
    "decap-cms-lib-auth": "catalog:decap",
    "decap-cms-lib-util": "catalog:decap",
    "decap-cms-ui-auth": "catalog:decap",
    "decap-cms-ui-default": "catalog:decap",
    "lucide-react": "catalog:icons",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "react-redux": "^7.2.0"
  },
