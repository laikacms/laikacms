      "optional": true
    },
    "@octokit/rest": {
      "optional": true
    },
    "@radix-ui/react-icons": {
      "optional": true
    },
    "decap-cms-backend-github": {
      "optional": true
    },
    "decap-cms-core": {
      "optional": true
    },
    "decap-cms-lib-auth": {
      "optional": true
    },
    "decap-cms-lib-util": {
      "optional": true
    },
    "decap-cms-ui-auth": {
      "optional": true
    },
    "decap-cms-ui-default": {
      "optional": true
    },
    "lucide-react": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "react-redux": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "@types/jwt-decode": "^3.1.0",
    "@types/node": "catalog:types",
    "@types/react": "catalog:types",
    "@types/react-dom": "catalog:types",
    "@types/react-redux": "^7.1.34",
    "@types/uuid": "^10.0.0",
    "immutable": "catalog:legacy",
    "rimraf": "catalog:tools",
    "typescript": "catalog:tools",
    "vitest": "catalog:tools"
  },
  "engines": {
    "node": "22.x"
  }
}
