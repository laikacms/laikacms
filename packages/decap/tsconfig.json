{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "ignoreDeprecations": "6.0",
    "rootDir": "src",
    "outDir": "dist",
    "baseUrl": ".",
    "types": ["node"],
    "typeRoots": ["../../types", "./node_modules/@types", "../../node_modules/@types"],
    "paths": {
      "decap-cms-core": ["../../types/decap-cms-core/index.d.ts"],
      "decap-cms-core/*": ["../../types/decap-cms-core/*"],
      "decap-cms-lib-util": ["../../types/decap-cms-lib-util/index.d.ts"],
      "decap-cms-lib-util/*": ["../../types/decap-cms-lib-util/*"],
      "decap-cms-ui-default": ["../../types/decap-cms-ui-default/index.d.ts"],
      "decap-cms-ui-default/*": ["../../types/decap-cms-ui-default/*"],
      "decap-cms-ui-auth": ["../../types/decap-cms-ui-auth/index.d.ts"],
      "decap-cms-ui-auth/*": ["../../types/decap-cms-ui-auth/*"],
      "decap-cms-lib-auth": ["../../types/decap-cms-lib-auth/index.d.ts"],
      "decap-cms-lib-auth/*": ["../../types/decap-cms-lib-auth/*"],
      "decap-cms-backend-github": ["../../types/decap-cms-backend-github/index.d.ts"],
      "decap-cms-backend-github/*": ["../../types/decap-cms-backend-github/*"],
      "decap-cms-widget-id": ["../../types/decap-cms-widget-id/index.d.ts"],
      "decap-cms-widget-id/*": ["../../types/decap-cms-widget-id/*"],
      "decap-cms-widget-markdown": ["../../types/decap-cms-widget-markdown/index.d.ts"],
      "decap-cms-widget-markdown/*": ["../../types/decap-cms-widget-markdown/*"],
      "decap-cms-widget-permalink": ["../../types/decap-cms-widget-permalink/index.d.ts"],
      "decap-cms-widget-permalink/*": ["../../types/decap-cms-widget-permalink/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "dist",
    "node_modules",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
