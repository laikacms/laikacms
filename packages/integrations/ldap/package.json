{
  "name": "@laikacms/ldap",
  "version": "1.0.0",
  "private": true,
  "description": "LDAP-backed StorageRepository for Laika CMS. DN-hierarchical addressing with objectClass schemas, LDAP search filters, and bulkOps atomic batches. Client-agnostic — depends on a structural `LdapOps` interface.",
  "keywords": [
    "headless-cms",
    "content-management",
    "ldap",
    "directory",
    "dn",
    "storage"
  ],
  "author": {
    "name": "Sem Postma",
    "email": "sem@laikacms.com",
    "url": "https://sem-postma.com"
  },
  "homepage": "https://github.com/laikacms/laikacms",
  "bugs": {
    "email": "sem@laikacms.com",
    "url": "https://github.com/laikacms/laikacms/issues"
  },
  "license": "MIT",
  "repository": "https://github.com/laikacms/laikacms",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "exports": {
    "./storage-ldap": {
      "types": "./dist/storage-ldap/index.d.ts",
      "import": "./dist/storage-ldap/index.js",
      "default": "./dist/storage-ldap/index.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist .turbo",
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "laikacms": "workspace:*",
    "effect": "catalog:default",
    "minimatch": "^10.0.3"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "rimraf": "catalog:tools",
    "typescript": "catalog:tools",
    "vitest": "catalog:tools"
  },
  "engines": {
    "node": ">=22"
  }
}
