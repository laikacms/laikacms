{
  "name": "@laikacms/storage-r2",
  "version": "0.1.0",
  "type": "module",
  "description": "Cloudflare R2-backed storage adapter implementation for Laika CMS.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "Sem Postma <sem@laikacms.com>",
  "license": "MIT",
  "engines": {
    "node": "22.x"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rimraf dist",

    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@laikacms/core": "workspace:*",
    "@laikacms/storage": "workspace:*",
    "@types/json-schema": "^7.0.15",
    "effect": "catalog:default",
    "minimatch": "^10.0.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "@types/node": "catalog:types",
    "typescript": "catalog:tools"
  }
}
