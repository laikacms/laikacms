{
  "name": "@laikacms/documents-contentbase",
  "version": "0.0.1",
  "type": "module",
  "description": "Default implementation of the documents module for Laika CMS.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "Sem Postma <sem@laikacms.com>",
  "license": "MIT",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@laikacms/core": "workspace:*",
    "@laikacms/storage": "workspace:*",
    "@laikacms/documents": "workspace:*",
    "@laikacms/contentbase-settings": "workspace:*",
    "effect": "catalog:default"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "@vitest/ui": "catalog:testing",
    "typescript": "catalog:tools",
    "vitest": "catalog:testing"
  }
}