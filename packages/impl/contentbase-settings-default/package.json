{
  "name": "@laikacms/contentbase-settings-default",
  "version": "0.1.2",
  "type": "module",
  "description": "Default implementation of the contentbase-settings module for Laika CMS.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "Sem Postma <sem@laikacms.com>",
  "license": "MIT",
  "engines": {
    "node": "22.x"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@laikacms/core": "workspace:^",
    "@laikacms/storage": "workspace:^",
    "@laikacms/documents": "workspace:^",
    "@laikacms/contentbase-settings": "workspace:^",
    "effect": "catalog:default",
    "ajv": "catalog:schema",
    "json-schema": "catalog:schema"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "typescript": "catalog:tools",
    "@types/json-schema": "catalog:types"
  }
}
