{
  "name": "@laikacms/storage-fs",
  "version": "0.0.1",
  "type": "module",
  "description": "Filesystem-backed storage adapter implementation for Laika CMS.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "Sem Postma <sem@esstudio.nl>",
  "license": "MIT",
  "engines": {
    "node": "22.x"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@laikacms/core": "workspace:*",
    "@laikacms/storage": "workspace:*",
    "@types/json-schema": "^7.0.15",
    "minimatch": "^10.0.3",
    "trash": "^9.0.0",
    "zod": "catalog:schema",
    "effect": "catalog:default"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "typescript": "catalog:tools"
  }
}