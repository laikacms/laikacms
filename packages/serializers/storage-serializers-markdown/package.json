{
  "name": "@laikacms/storage-serializers-markdown",
  "version": "0.1.1",
  "type": "module",
  "description": "Markdown document serializer for Laika CMS storage",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "Sem Postma <sem@laikacms.com>",
  "license": "MIT",
  "engines": {
    "node": "22.x"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json -w",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@laikacms/storage": "workspace:^",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/json-schema": "^7.0.15",
    "typescript": "catalog:tools"
  }
}
