{
  "name": "@laikacms/assets",
  "version": "0.0.1",
  "type": "module",
  "description": "Assets interface for Laika CMS - binary files, images, and media management.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "Sem Postma <sem@esstudio.nl>",
  "license": "MIT",
  "engines": {
    "node": "22.x"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json -w",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "typescript": "catalog:tools"
  },
  "dependencies": {
    "@laikacms/core": "workspace:*",
    "@laikacms/storage": "workspace:*",
    "effect": "catalog:default"
  }
}
