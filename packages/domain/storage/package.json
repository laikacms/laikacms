{
  "name": "@laikacms/storage",
  "version": "0.1.1",
  "type": "module",
  "description": "Storage interface for Laika CMS.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "Sem Postma <sem@laikacms.com>",
  "license": "MIT",
  "engines": {
    "node": "22.x"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json -w",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/json-schema": "^7.0.15",
    "typescript": "catalog:tools",
    "@standard-schema/spec": "catalog:schema"
  },
  "dependencies": {
    "@laikacms/core": "workspace:^",
    "effect": "catalog:default"
  }
}
