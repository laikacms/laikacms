{
  "name": "portable-text-to-contentful-rtf-mapper",
  "description": "Contentful Rich Text <-> Portable Text mapper.",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "engines": {
    "node": "22.x"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@laikacloud/portabletext-core": "workspace:*",
    "@contentful/rich-text-types": "catalog:contentful",
    "@portabletext/types": "catalog:portabletext"
  },
  "devDependencies": {
    "rimraf": "catalog:tools",
    "typescript": "catalog:tools",
    "vitest": "catalog:testing"
  }
}
