{
  "name": "@laikacms/starter-vite-react-blog",
  "version": "0.0.1",
  "private": true,
  "description": "Starter blog using bare Vite SSR + React + Express + LaikaCMS. No meta-framework — shows what Next.js and TanStack Start abstract away: server-side renderToString, Express request handling, and the Decap proxy.",
  "type": "module",
  "scripts": {
    "build:admin": "esbuild src/admin-client.ts --bundle --outfile=public/admin/bundle.js --format=esm --platform=browser",
    "dev": "pnpm build:admin && tsx watch src/server.tsx",
    "build": "pnpm build:admin",
    "start": "tsx src/server.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@laikacms/decap-integrations": "workspace:*",
    "express": "^5.1.0",
    "laikacms": "workspace:*",
    "react": "catalog:react",
    "react-dom": "catalog:react"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "catalog:types",
    "@types/react": "catalog:types",
    "@types/react-dom": "catalog:types",
    "@vitejs/plugin-react": "catalog:react",
    "esbuild": "catalog:tools",
    "tsx": "catalog:tools",
    "typescript": "catalog:tools",
    "vite": "catalog:tools"
  },
  "engines": {
    "node": "22.x"
  }
}
