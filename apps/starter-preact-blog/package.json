{
  "name": "@laikacms/starter-preact-blog",
  "version": "0.0.1",
  "private": true,
  "description": "Starter blog using Preact SSR + Hono + LaikaCMS. Shows React-compatible JSX rendering with preact-render-to-string — no Vite, no React runtime, tsx handles TSX compilation on the fly.",
  "type": "module",
  "scripts": {
    "build:admin": "esbuild src/admin-client.tsx --bundle --outfile=public/admin/bundle.js --format=esm --platform=browser --jsx=automatic --jsx-import-source=preact",
    "dev": "pnpm build:admin && tsx watch src/server.tsx",
    "start": "tsx src/server.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "catalog:server",
    "@laikacms/decap-integrations": "workspace:*",
    "hono": "catalog:server",
    "laikacms": "workspace:*",
    "preact": "^10.25.0",
    "preact-render-to-string": "^6.5.0"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "esbuild": "catalog:tools",
    "tsx": "catalog:tools",
    "typescript": "catalog:tools"
  },
  "engines": {
    "node": "22.x"
  }
}
