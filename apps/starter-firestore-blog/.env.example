# Firebase / Google Cloud project ID
# Found at: Firebase Console → Project Settings → General → Project ID
FIREBASE_PROJECT_ID=my-project-id

# Service account JSON key (as a single-line string with \n for newlines)
# Create at: Firebase Console → Project Settings → Service accounts → Generate new private key
# Then: cat service-account.json | tr -d '\n' | sed 's/"/\\"/g'
# Or paste the raw JSON here (it will be parsed)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Firestore database ID (leave as "(default)" unless you created a named database)
# FIRESTORE_DATABASE_ID=(default)
