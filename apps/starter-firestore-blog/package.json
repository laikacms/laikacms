{
  "name": "@laikacms/starter-firestore-blog",
  "version": "0.0.1",
  "private": true,
  "description": "Starter blog backed by Google Cloud Firestore. Content stored in a Firestore collection tree; full CRUD via Firestore REST API; Application Default Credentials for auth; Decap admin from CDN.",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "catalog:server",
    "@laikacms/decap-integrations": "workspace:*",
    "@laikacms/firestore": "workspace:*",
    "google-auth-library": "^9.0.0",
    "hono": "catalog:server",
    "laikacms": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "tsx": "catalog:tools",
    "typescript": "catalog:tools"
  },
  "engines": {
    "node": "22.x"
  }
}
