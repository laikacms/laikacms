{
  "name": "@laikacms/starter-contentful-blog",
  "version": "0.0.1",
  "private": true,
  "description": "Starter blog backed by Contentful (Content Management API). Structured fields instead of blobs; native OCC via sys.version; createFolder auto-activates a content type. Decap admin from CDN.",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "catalog:server",
    "@laikacms/contentful": "workspace:*",
    "@laikacms/decap-integrations": "workspace:*",
    "hono": "catalog:server",
    "laikacms": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "tsx": "catalog:tools",
    "typescript": "catalog:tools"
  },
  "engines": {
    "node": "22.x"
  }
}
