{
  "name": "@laikacms/starter-pocketbase-blog",
  "version": "0.0.1",
  "private": true,
  "description": "Starter blog built with Hono + PocketBase + LaikaCMS. Uses @laikacms/pocketbase/storage-pb — a pure-fetch PocketBase REST adapter. Self-host PocketBase (single Go binary) or use PocketBase Cloud.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "catalog:server",
    "@laikacms/decap-integrations": "workspace:*",
    "@laikacms/pocketbase": "workspace:*",
    "hono": "catalog:server",
    "laikacms": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "tsx": "catalog:tools",
    "typescript": "catalog:tools"
  },
  "engines": {
    "node": ">=22"
  }
}
