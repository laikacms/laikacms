# PocketBase instance URL (no trailing slash)
# Local: http://localhost:8090
# Cloud: https://your-instance.pockethost.io
POCKETBASE_URL=http://localhost:8090

# Superuser credentials (create in PocketBase admin UI at /admin or /_/)
# These are used to obtain an auth token on startup.
POCKETBASE_EMAIL=admin@example.com
POCKETBASE_PASSWORD=your-admin-password
