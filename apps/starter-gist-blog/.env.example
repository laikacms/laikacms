# ID of an existing GitHub Gist (the 32-char hex from the gist URL).
# Create one at https://gist.github.com — even an empty placeholder gist works.
GIST_ID=your-gist-id

# GitHub Personal Access Token with `gist` scope.
# Create at https://github.com/settings/tokens (classic) → select "gist".
GITHUB_PAT=ghp_your-token

# Optional: HTTP port (default: 3000)
# PORT=3000
