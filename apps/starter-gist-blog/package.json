{
  "name": "@laikacms/starter-gist-blog",
  "version": "0.0.1",
  "private": true,
  "description": "Starter blog using GitHub Gist as the content store via GistStorageRepository + createCustomLaika. Demonstrates atomic multi-file PATCH, / → __ filename encoding, and single-gist-scoped storage.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "catalog:server",
    "@laikacms/decap-integrations": "workspace:*",
    "@laikacms/gist": "workspace:*",
    "hono": "catalog:server",
    "laikacms": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "tsx": "catalog:tools",
    "typescript": "catalog:tools"
  },
  "engines": {
    "node": "22.x"
  }
}
