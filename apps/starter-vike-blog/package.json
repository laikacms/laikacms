{
  "name": "@laikacms/starter-vike-blog",
  "version": "0.0.1",
  "private": true,
  "description": "Starter blog built with Vike (vite-plugin-ssr) + React + LaikaCMS. Framework-agnostic SSR: +data.ts files load content at request time via laika.documents.*, Decap admin bootstrapped client-side via useEffect.",
  "type": "module",
  "scripts": {
    "dev": "tsx server/index.ts",
    "build": "vite build",
    "start": "NODE_ENV=production tsx server/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@laikacms/decap-integrations": "workspace:*",
    "express": "^5.1.0",
    "laikacms": "workspace:*",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "vike": "^0.4.0",
    "vike-react": "^0.6.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "catalog:types",
    "@types/react": "catalog:types",
    "@types/react-dom": "catalog:types",
    "@vitejs/plugin-react": "catalog:react",
    "tsx": "catalog:tools",
    "typescript": "catalog:tools",
    "vite": "catalog:tools"
  },
  "engines": {
    "node": "22.x"
  }
}
