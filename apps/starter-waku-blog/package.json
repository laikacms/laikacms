{
  "name": "@laikacms/starter-waku-blog",
  "version": "0.0.1",
  "private": true,
  "description": "Starter blog built with Waku (minimal React RSC framework) + LaikaCMS. laika.documents.* in React Server Components; laika.fetch in Waku API routes (no IncomingMessage bridge — Waku passes Web API Request natively).",
  "type": "module",
  "scripts": {
    "build:admin": "esbuild src/admin-client.ts --bundle --outfile=public/admin/bundle.js --format=esm --platform=browser",
    "dev": "pnpm build:admin && waku dev",
    "build": "pnpm build:admin && waku build",
    "start": "waku start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@laikacms/decap-integrations": "workspace:*",
    "laikacms": "workspace:*",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "react-server-dom-webpack": "~19.2.4",
    "waku": "^1.0.0-beta.1"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "@types/react": "catalog:types",
    "@types/react-dom": "catalog:types",
    "esbuild": "catalog:tools",
    "typescript": "catalog:tools"
  },
  "engines": {
    "node": "22.x"
  }
}
