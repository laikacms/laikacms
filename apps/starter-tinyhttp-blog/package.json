{
  "name": "@laikacms/starter-tinyhttp-blog",
  "version": "0.0.1",
  "private": true,
  "description": "Starter blog built with tinyhttp + LaikaCMS on Node.js. Shows how to bridge tinyhttp req/res to the Web API Request/Response that laika.fetch expects.",
  "type": "module",
  "scripts": {
    "build:admin": "esbuild src/admin-client.ts --bundle --outfile=public/admin/bundle.js --format=esm --platform=browser",
    "dev": "pnpm build:admin && tsx watch src/index.ts",
    "build": "pnpm build:admin",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@laikacms/decap-integrations": "workspace:*",
    "@tinyhttp/app": "^3.0.7",
    "laikacms": "workspace:*",
    "sirv": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "esbuild": "catalog:tools",
    "tsx": "catalog:tools",
    "typescript": "catalog:tools"
  },
  "engines": {
    "node": "22.x"
  }
}
