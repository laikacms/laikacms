{
  "name": "@laikacms/starter-koa-blog",
  "version": "0.0.1",
  "private": true,
  "description": "Starter blog built with Koa v2 + LaikaCMS. Shows async middleware composition and the WHATWG Request bridge for laika.fetch.",
  "type": "module",
  "scripts": {
    "build:admin": "esbuild src/admin-client.ts --bundle --outfile=public/admin/bundle.js --format=esm --platform=browser",
    "dev": "pnpm build:admin && tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@koa/router": "^13.1.0",
    "@laikacms/decap-integrations": "workspace:*",
    "koa": "^2.16.1",
    "koa-static": "^5.0.0",
    "laikacms": "workspace:*"
  },
  "devDependencies": {
    "@types/koa": "^2.15.0",
    "@types/koa__router": "^12.0.4",
    "@types/koa-static": "^4.0.4",
    "@types/node": "catalog:types",
    "esbuild": "catalog:tools",
    "tsx": "catalog:tools",
    "typescript": "catalog:tools"
  },
  "engines": {
    "node": "22.x"
  }
}
