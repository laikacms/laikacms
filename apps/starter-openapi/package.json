{
  "name": "@laikacms/starter-openapi",
  "description": "Starter: typed REST API with auto-generated OpenAPI spec + Scalar UI. Hono + @hono/zod-openapi. Backend devs get browsable docs for free.",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "catalog:server",
    "@hono/zod-openapi": "^0.18.0",
    "@laikacms/decap-integrations": "workspace:*",
    "@scalar/hono-api-reference": "^0.5.0",
    "hono": "catalog:server",
    "laikacms": "workspace:*",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "tsx": "catalog:tools",
    "typescript": "catalog:tools"
  }
}
