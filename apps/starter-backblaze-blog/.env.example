# Backblaze B2 credentials — provision an application key in the B2 dashboard.
# Both values are shown exactly once at key creation time.
B2_KEY_ID=your-key-id
B2_APPLICATION_KEY=your-application-key

# Bucket identifiers — both are required (B2 uses IDs for writes, names for downloads).
B2_BUCKET_ID=your-bucket-id
B2_BUCKET_NAME=your-bucket-name

# Optional: subfolder within the bucket (default: cms)
# B2_BASE_PATH=cms

# Optional: HTTP port (default: 3000)
# PORT=3000
