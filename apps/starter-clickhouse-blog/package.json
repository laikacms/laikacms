{
  "name": "@laikacms/starter-clickhouse-blog",
  "version": "0.0.1",
  "private": true,
  "description": "Starter blog backed by ClickHouse. Content stored in a ReplacingMergeTree table; NDJSON wire format; X-ClickHouse-User/Key auth; Decap admin from CDN.",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "catalog:server",
    "@laikacms/clickhouse": "workspace:*",
    "@laikacms/decap-integrations": "workspace:*",
    "hono": "catalog:server",
    "laikacms": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "tsx": "catalog:tools",
    "typescript": "catalog:tools"
  },
  "engines": {
    "node": "22.x"
  }
}
