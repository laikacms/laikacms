{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "noImplicitOverride": true,
    "skipLibCheck": true,
    "rootDir": "./",
    "outDir": "./build",
    "noEmit": true,
    "paths": {
      "#controllers/*": ["./app/controllers/*.js"],
      "#services/*": ["./app/services/*.js"],
      "#config/*": ["./config/*.js"],
      "#start/*": ["./start/*.js"]
    },
    "types": ["node"]
  },
  "include": ["**/*.ts"],
  "exclude": ["build", "node_modules", "resources/admin-client.ts"]
}
