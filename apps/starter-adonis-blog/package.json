{
  "name": "@laikacms/starter-adonis-blog",
  "version": "0.0.1",
  "private": true,
  "description": "Starter blog built with AdonisJS v6 + LaikaCMS. AdonisJS is ESM-native so it can import laikacms directly without the dynamic import() workaround required in CommonJS frameworks like NestJS.",
  "type": "module",
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#services/*": "./app/services/*.js",
    "#config/*": "./config/*.js",
    "#start/*": "./start/*.js"
  },
  "scripts": {
    "build:admin": "esbuild resources/admin-client.ts --bundle --outfile=public/admin/bundle.js --format=esm --platform=browser --tsconfig=tsconfig.admin.json",
    "dev": "pnpm build:admin && node ace serve --watch",
    "build": "pnpm build:admin && node ace build",
    "start": "node bin/server.js",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.admin.json --noEmit"
  },
  "dependencies": {
    "@adonisjs/core": "^6.15.1",
    "@adonisjs/static": "^1.1.0",
    "@laikacms/decap-integrations": "workspace:*",
    "reflect-metadata": "^0.2.2",
    "laikacms": "workspace:*",
    "luxon": "^3.5.0"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^7.8.2",
    "@japa/assert": "^3.0.0",
    "@japa/runner": "^3.1.4",
    "@types/luxon": "^3.4.2",
    "@types/node": "catalog:types",
    "esbuild": "catalog:tools",
    "typescript": "catalog:tools"
  },
  "engines": {
    "node": "22.x"
  }
}
