# Gel (formerly EdgeDB) connection
# https://docs.geldata.com/guides/connection

# HTTP EdgeQL endpoint — Gel's HTTP protocol (not the binary protocol)
GEL_URL=http://localhost:5656

# Branch — Gel supports multiple branches per instance (like git)
GEL_BRANCH=main

# Auth — for local dev instances the default user is "gel" or "edgedb"
GEL_USER=gel
GEL_PASSWORD=

PORT=3000
