{
  "name": "@laikacms/starter-angular-blog",
  "version": "0.0.1",
  "private": true,
  "description": "Starter blog built with Angular 19 SSR + LaikaCMS. Demonstrates createEmbeddedLaika, Angular HttpClient blog routes with an SSR base-URL interceptor, and Decap admin via decapAdminHtml().",
  "scripts": {
    "dev": "ng serve",
    "build": "ng build",
    "start": "node dist/starter-angular-blog/server/server.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.app.json"
  },
  "dependencies": {
    "@angular/animations": "^19.0.0",
    "@angular/common": "^19.0.0",
    "@angular/compiler": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/forms": "^19.0.0",
    "@angular/platform-browser": "^19.0.0",
    "@angular/platform-server": "^19.0.0",
    "@angular/router": "^19.0.0",
    "@angular/ssr": "^19.0.0",
    "@laikacms/decap-integrations": "workspace:*",
    "express": "^4.18.0",
    "laikacms": "workspace:*",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.0.0",
    "@angular/cli": "^19.0.0",
    "@angular/compiler-cli": "^19.0.0",
    "@types/express": "^4.17.0",
    "@types/node": "catalog:types",
    "typescript": "~5.5.4"
  },
  "engines": {
    "node": "22.x"
  }
}
