# Pinata API JWT — create at https://app.pinata.cloud/developers/api-keys
# Requires at minimum: pinFileToIPFS, unpin, pinList (or Admin key for dev).
PINATA_JWT=your-pinata-jwt

# Optional: dedicated IPFS gateway URL for faster, non-rate-limited downloads.
# Provision at https://app.pinata.cloud/gateway
# PINATA_GATEWAY_URL=https://your-name.mypinata.cloud/ipfs

# Optional: HTTP port (default: 3000)
# PORT=3000
