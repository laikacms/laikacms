{
  "name": "@laikacms/starter-analog-blog",
  "version": "0.0.1",
  "private": true,
  "description": "Starter blog built with Analog (Angular meta-framework) + LaikaCMS. Demonstrates createEmbeddedLaika, route load functions for SSR data, Nitro API routes, and afterNextRender for client-only Decap bootstrap.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "node dist/analog/server/index.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.app.json"
  },
  "dependencies": {
    "@analogjs/platform": "^1.0.0",
    "@analogjs/router": "^1.0.0",
    "@angular/common": "^19.0.0",
    "@angular/compiler": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/platform-browser": "^19.0.0",
    "@angular/platform-browser-dynamic": "^19.0.0",
    "@angular/platform-server": "^19.0.0",
    "@angular/router": "^19.0.0",
    "@laikacms/decap-integrations": "workspace:*",
    "laikacms": "workspace:*",
    "h3": "^1.15.0",
    "rxjs": "^7.8.0",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "typescript": "catalog:tools",
    "vite": "catalog:tools"
  },
  "engines": {
    "node": "22.x"
  }
}
