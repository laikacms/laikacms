{
  "name": "@laikacms/starter-express-ejs-blog",
  "version": "0.0.1",
  "private": true,
  "description": "Starter blog using Express + EJS templates + LaikaCMS. Traditional server-side template rendering — no components, no JSX, just HTML templates with embedded JS expressions.",
  "type": "module",
  "scripts": {
    "build:admin": "esbuild src/admin-client.ts --bundle --outfile=public/admin/bundle.js --format=esm --platform=browser",
    "dev": "pnpm build:admin && tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@laikacms/decap-integrations": "workspace:*",
    "ejs": "^3.1.10",
    "express": "^5.1.0",
    "laikacms": "workspace:*"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.0",
    "@types/node": "catalog:types",
    "esbuild": "catalog:tools",
    "tsx": "catalog:tools",
    "typescript": "catalog:tools"
  },
  "engines": {
    "node": "22.x"
  }
}
