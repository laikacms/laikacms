# Turso / libSQL credentials
# Create a free database at https://turso.tech/
# Then run: turso db show <db-name> (URL) + turso db tokens create <db-name> (token)
LIBSQL_URL=https://your-db-name-your-org.turso.io
LIBSQL_AUTH_TOKEN=your-turso-auth-token

# For local sqld (no auth needed):
# LIBSQL_URL=http://localhost:8080
# LIBSQL_AUTH_TOKEN=  (leave blank)
