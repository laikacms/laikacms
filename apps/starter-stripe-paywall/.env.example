# Get from https://dashboard.stripe.com/test/apikeys (use the **test** keys).
STRIPE_SECRET_KEY=sk_test_...

# Create a recurring product + price in the Stripe dashboard, paste the price ID here.
STRIPE_PRICE_ID=price_...

# Get from the Stripe CLI: `stripe listen --forward-to localhost:3000/stripe/webhook`
# The CLI prints the signing secret on first run.
STRIPE_WEBHOOK_SECRET=whsec_...

# Random string used to sign session cookies. Generate with `openssl rand -hex 32`.
SESSION_SECRET=replace-me-with-a-real-secret

# Where Stripe redirects after Checkout success / cancel.
PUBLIC_URL=http://localhost:3000
