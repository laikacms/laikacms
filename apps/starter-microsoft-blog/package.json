{
  "name": "@laikacms/starter-microsoft-blog",
  "version": "0.0.1",
  "private": true,
  "description": "Starter blog backed by Microsoft OneDrive (Graph API). Uses native path addressing, $batch bulk deletes, and pre-signed downloadUrl for content reads. Decap admin from CDN.",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "catalog:server",
    "@laikacms/decap-integrations": "workspace:*",
    "@laikacms/microsoft": "workspace:*",
    "hono": "catalog:server",
    "laikacms": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "tsx": "catalog:tools",
    "typescript": "catalog:tools"
  },
  "engines": {
    "node": "22.x"
  }
}
