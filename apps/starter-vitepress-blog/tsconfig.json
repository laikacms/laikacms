{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
    ".vitepress/**/*.ts",
    "docs/**/*.ts"
  ],
  "exclude": ["node_modules", "src/admin-client.ts", ".vitepress/dist"]
}
