# Full CouchDB database URL including the database name.
# You can embed credentials directly in the URL or use COUCH_USERNAME / COUCH_PASSWORD below.
COUCH_URL=http://admin:password@localhost:5984/cms

# Optional: separate credentials (used when COUCH_USERNAME is set; takes precedence over URL-embedded creds)
# COUCH_USERNAME=admin
# COUCH_PASSWORD=password

# Optional: HTTP port (default: 3000)
# PORT=3000
