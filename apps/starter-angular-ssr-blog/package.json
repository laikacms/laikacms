{
  "name": "@laikacms/starter-angular-ssr-blog",
  "version": "0.0.1",
  "private": true,
  "description": "Starter blog with Angular 21 SSR + Express + LaikaCMS. Uses @analogjs/vite-plugin-angular for template compilation and renderApplication() from @angular/platform-server. Demonstrates what Analog/Nitro abstracts: explicit Vite SSR pipeline, renderApplication, and the Express↔WHATWG fetch adapter.",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "vite build && vite build --ssr",
    "start": "NODE_ENV=production tsx src/server.ts",
    "typecheck": "tsc --noEmit -p tsconfig.app.json"
  },
  "dependencies": {
    "@angular/common": "^21.2.13",
    "@angular/compiler": "^21.2.13",
    "@angular/core": "^21.2.13",
    "@angular/platform-browser": "^21.2.13",
    "@angular/platform-server": "^21.2.13",
    "@angular/router": "^21.2.13",
    "@laikacms/decap-integrations": "workspace:*",
    "express": "^5.1.0",
    "laikacms": "workspace:*",
    "rxjs": "^7.8.0",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.5.2",
    "@angular/build": "21.2.13",
    "@angular/compiler-cli": "21.2.13",
    "@types/express": "^5.0.3",
    "@types/node": "catalog:types",
    "tsx": "catalog:tools",
    "typescript": "catalog:tools",
    "vite": "catalog:tools"
  },
  "engines": {
    "node": "22.x"
  }
}
