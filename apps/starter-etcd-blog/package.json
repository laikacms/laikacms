{
  "name": "@laikacms/starter-etcd-blog",
  "version": "0.0.1",
  "private": true,
  "description": "Starter blog using etcd (Kubernetes' backing store) via EtcdStorageRepository + createCustomLaika. Demonstrates base64-encoded wire format, prefix range scans, and Txn CAS atomic writes.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "etcd:up": "docker run -d --name laikacms-etcd -p 2379:2379 -e ALLOW_NONE_AUTHENTICATION=yes bitnami/etcd:latest",
    "etcd:down": "docker rm -f laikacms-etcd || true"
  },
  "dependencies": {
    "@hono/node-server": "catalog:server",
    "@laikacms/decap-integrations": "workspace:*",
    "@laikacms/etcd": "workspace:*",
    "hono": "catalog:server",
    "laikacms": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "tsx": "catalog:tools",
    "typescript": "catalog:tools"
  },
  "engines": {
    "node": "22.x"
  }
}
