---
// This page is prerendered (default in output: 'static' mode).
// getCollection() reads from Astro's Content Layer store populated at build time
// by laikaPostsLoader — no runtime HTTP calls.
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
posts.sort((a, b) => {
  const aDate = a.data.date ? new Date(a.data.date).getTime() : 0;
  const bDate = b.data.date ? new Date(b.data.date).getTime() : 0;
  return bDate - aDate;
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>My Blog</title>
  </head>
  <body>
    <h1>My Blog</h1>
    {
      posts.length === 0 ? (
        <p>
          No posts yet. <a href="/admin">Open the CMS</a> to write your first post, then rebuild.
        </p>
      ) : (
        <ul style="list-style:none;padding:0">
          {posts.map(post => (
            <li style="margin-bottom:1rem">
              <a href={`/blog/${post.id}`}>{post.data.title ?? post.id}</a>
              {post.data.date && (
                <time> · {new Date(post.data.date).toLocaleDateString()}</time>
              )}
            </li>
          ))}
        </ul>
      )
    }
    <p><a href="/admin">Admin →</a></p>
  </body>
</html>
