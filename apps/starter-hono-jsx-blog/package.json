{
  "name": "@laikacms/starter-hono-jsx-blog",
  "version": "0.0.1",
  "private": true,
  "description": "Starter blog using Hono's built-in JSX renderer + LaikaCMS. Zero extra dependencies: hono/jsx provides the JSX runtime — no React, no Preact, no Vite.",
  "type": "module",
  "scripts": {
    "build:admin": "esbuild src/admin-client.ts --bundle --outfile=public/admin/bundle.js --format=esm --platform=browser",
    "dev": "pnpm build:admin && tsx watch src/server.tsx",
    "start": "tsx src/server.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "catalog:server",
    "@laikacms/decap-integrations": "workspace:*",
    "hono": "catalog:server",
    "laikacms": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "esbuild": "catalog:tools",
    "tsx": "catalog:tools",
    "typescript": "catalog:tools"
  },
  "engines": {
    "node": "22.x"
  }
}
