{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["app/**/*.ts", "app/**/*.tsx", "src/**/*.ts", "vite.config.ts"],
  "exclude": ["node_modules", "src/admin-client.ts", "dist"]
}
