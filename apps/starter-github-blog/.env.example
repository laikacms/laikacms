# GitHub App credentials
# Create a GitHub App at https://github.com/settings/apps/new
# Required permissions: Contents (Read & Write), Metadata (Read)
# Install the app on your content repo and note the installation ID.
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# GitHub App installation — find it at:
# https://github.com/settings/installations/<id> (personal)
# https://github.com/organizations/<org>/settings/installations/<id>
GITHUB_APP_INSTALLATION_ID=12345678

# The GitHub repo that stores your content
GITHUB_OWNER=your-org-or-username
GITHUB_REPO=your-content-repo
GITHUB_BRANCH=main
