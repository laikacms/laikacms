# GitHub App credentials. Create an app at
# https://github.com/settings/apps/new and install it on the repo you want
# LaikaCMS to write to.

# The numeric "App ID" from the app's settings page.
GITHUB_APP_ID=

# The PEM private key from the app's settings page. Paste with literal `\n`
# for newlines, e.g.:
#   GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEow...\n-----END RSA PRIVATE KEY-----"
GITHUB_PRIVATE_KEY=

# The installation ID for THIS repo. Find it at
# https://github.com/settings/installations after installing the app.
GITHUB_INSTALLATION_ID=

# The repo to write to.
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main

# Commits will be authored as this person.
COMMIT_AUTHOR_NAME=LaikaCMS
COMMIT_AUTHOR_EMAIL=laikacms@bot.local
