# Resend (https://resend.com) for transactional email.
RESEND_API_KEY=re_...

# Sender address — must be verified in Resend.
FROM_EMAIL=hello@your-domain.example.com

# Public site URL — used in email links.
PUBLIC_URL=http://localhost:3000

# Where the subscriber list lives. JSON file by default (the starter is
# meant as a reference; production should use a real DB).
SUBSCRIBERS_FILE=./data/subscribers.json
