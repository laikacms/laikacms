{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "noImplicitAny": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "include": [
    "main.ts",
    "dev.ts",
    "fresh.config.ts",
    "fresh.gen.ts",
    "routes/**/*.ts",
    "routes/**/*.tsx",
    "lib/**/*.ts"
  ]
}
