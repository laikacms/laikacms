{
  "name": "@laikacms/starter-tanstack-blog",
  "version": "0.0.1",
  "private": true,
  "description": "Starter blog built with TanStack Start + LaikaCMS. SSR via server functions, Decap proxy via server route ANY handler, admin via useEffect.",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "typecheck": "vite build && tsc --noEmit"
  },
  "dependencies": {
    "@laikacms/decap-integrations": "workspace:*",
    "@tanstack/react-router": "catalog:tanstack",
    "@tanstack/react-start": "catalog:tanstack",
    "laikacms": "workspace:*",
    "react": "catalog:react",
    "react-dom": "catalog:react"
  },
  "devDependencies": {
    "@tanstack/router-plugin": "catalog:tanstack",
    "@tanstack/start-server-core": "catalog:tanstack",
    "@types/node": "catalog:types",
    "@types/react": "catalog:types",
    "@types/react-dom": "catalog:types",
    "@vitejs/plugin-react": "catalog:react",
    "typescript": "catalog:tools",
    "vite": "catalog:tools"
  },
  "engines": {
    "node": "22.x"
  }
}
